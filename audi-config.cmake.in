@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Boost @_audi_MIN_BOOST_VERSION@ REQUIRED COMPONENTS serialization timer chrono unit_test_framework)
find_dependency(obake REQUIRED CONFIG)
find_dependency(Eigen3 REQUIRED CONFIG)
find_dependency(mp++ REQUIRED CONFIG)

#Get current dir.
get_filename_component(_AUDI_CONFIG_SELF_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)

include(${_AUDI_CONFIG_SELF_DIR}/audi_export.cmake)

#Clean up.
unset(_AUDI_CONFIG_SELF_DIR)
